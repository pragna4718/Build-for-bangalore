# ─── Server ────────────────────────────────────────────────
PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/preventai
JWT_SECRET=change_this_to_a_long_random_string
AI_SERVICE_URL=http://localhost:8000

# ─── Client (Vite) ─────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api

# ─── AI Service ────────────────────────────────────────────
# (AI service uses the same MONGODB_URI)

# ─── External APIs (Dev 2 — Exposome) ──────────────────────
OPENWEATHER_API_KEY=your_openweather_key
AQICN_API_KEY=your_aqicn_key
GOOGLE_CALENDAR_API_KEY=your_google_calendar_key
